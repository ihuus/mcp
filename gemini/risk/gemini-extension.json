{
  "name": "ihuus-risk",
  "version": "1.1.0",
  "description": "Provides tools for assessing natural hazard risk — flood safety and wildfire risk — via the iHuus Risk API.",
  "mcpServers": {
    "ihuus-risk": {
      "url": "https://api.ihuus.com/v1/mcp/risk/",
      "headers": {
        "Authorization": "Bearer $IHUUS_API_KEY"
      }
    },
    "ihuus-geospatial": {
      "url": "https://api.ihuus.com/v1/mcp/tools/",
      "headers": {
        "Authorization": "Bearer $IHUUS_API_KEY"
      }
    }
  }
}
