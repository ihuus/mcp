{
  "name": "ihuus-schools",
  "version": "1.1.0",
  "description": "Provides tools for accessing information about schools in California and Texas via the iHuus API.",
  "mcpServers": {
    "ihuus-schools": {
      "url": "https://api.ihuus.com/v1/mcp/schools/",
      "headers": {
        "Authorization": "Bearer $IHUUS_API_KEY"
      }
    },
    "ihuus-geospatial": {
      "url": "https://api.ihuus.com/v1/mcp/tools/",
      "headers": {
        "Authorization": "Bearer $IHUUS_API_KEY"
      }
    }
  }
}
