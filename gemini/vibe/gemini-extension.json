{
  "name": "ihuus-vibe",
  "version": "1.1.0",
  "description": "Provides tools for assessing neighborhood character and quality of life via the iHuus Vibe API.",
  "mcpServers": {
    "ihuus-vibe": {
      "url": "https://api.ihuus.com/v1/mcp/vibe/",
      "headers": {
        "Authorization": "Bearer $IHUUS_API_KEY"
      }
    },
    "ihuus-geospatial": {
      "url": "https://api.ihuus.com/v1/mcp/tools/",
      "headers": {
        "Authorization": "Bearer $IHUUS_API_KEY"
      }
    }
  }
}
