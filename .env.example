# ─── iHuus API ──────────────────────────────────────────────────────────────
# Get your API key at https://ihuus.com/pricing
# Documentation: https://docs.ihuus.com/
IHUUS_API_KEY=your_ihuus_api_key_here

# ─── Gemini CLI ──────────────────────────────────────────────────────────────
# Required when using extensions under gemini/
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Claude Desktop (Anthropic) ──────────────────────────────────────────────
# Required when using extensions under claude/
# Claude Desktop reads this automatically from its environment on macOS/Linux.
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
